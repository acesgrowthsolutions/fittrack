# Database
POSTGRES_URL=postgresql://dev_user:dev_password@localhost:5432/postgres_ss

# Authentication - Better Auth
# Generate key using https://www.better-auth.com/docs/installation
BETTER_AUTH_SECRET=replace-with-a-random-32-character-string

# Google OAuth (optional). Create credentials at:
# https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: <NEXT_PUBLIC_APP_URL>/api/auth/callback/google
# Leave both blank to disable Google sign-in.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# AI Integration via OpenRouter (Optional - for chat functionality)
# Get your API key from: https://openrouter.ai/settings/keys
# View available models at: https://openrouter.ai/models
OPENROUTER_API_KEY=
OPENROUTER_MODEL="openai/gpt-5-mini"
# Vision-capable model used for /meals photo analysis
OPENROUTER_VISION_MODEL="openai/gpt-4o-mini"

# App URL (for production deployments)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# File storage (optional - if app required file uploads)
BLOB_READ_WRITE_TOKEN=

# Terra (tryterra.co) — pulls steps/activity from Apple Health, Google Fit,
# Fitbit, Garmin, etc. into daily_stats via webhooks. Get keys at:
# https://dashboard.tryterra.co/
# When any of these is unset, the /api/integrations/terra/* routes return
# 503 and the "Connect health app" UI stays disabled — the rest of the app
# is unaffected.
TERRA_DEV_ID=
TERRA_API_KEY=
TERRA_WEBHOOK_SECRET=

# Email (transactional). Get a key at https://resend.com/api-keys
# When unset, password-reset and verification emails are logged to the
# terminal instead of sent — fine for local dev.
RESEND_API_KEY=
# Sender address. Defaults to onboarding@resend.dev which only delivers to
# the Resend account owner. For real users, verify your own domain in
# Resend and set EMAIL_FROM to e.g. "FitTrack <noreply@yourdomain.com>".
EMAIL_FROM=